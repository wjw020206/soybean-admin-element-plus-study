# 应用标题
VITE_APP_TITLE=soybean-admin-element-plus-study

# 应用基础路径（Base URL）
# 默认：/
# 如果部署在子路径，必须以 / 结尾，例如：
# 正确：/admin/
# 错误：/admin
VITE_BASE_URL=/

# iconify 图标的前缀
VITE_ICON_PREFIX=icon

# 本地 SVG 图标组件的前缀，必须包含 VITE_ICON_PREFIX
# 格式：{VITE_ICON_PREFIX}-{本地图标名称}
VITE_ICON_LOCAL_PREFIX=icon-local


# 开发模式下是否启用 HTTP 代理
VITE_HTTP_PROXY=Y

# 是否生成 source map 文件
VITE_SOURCE_MAP=N

# 存储键键前缀，用于区分不同域的存储
VITE_STORAGE_PREFIX=SOY_

# 是否在终端中显示代理 URL 日志
VITE_PROXY_LOG=Y

# 配置开发工具中打开代码所使用的编辑器
# 注意：此插件仅在开发模式下可用，在构建模式下不可用
VITE_DEVTOOLS_LAUNCH_EDITOR=code
