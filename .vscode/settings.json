{
  // 控制保存文件时自动执行哪些代码操作
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit", // 仅在显式保存时触发 ESLint 修复
    "source.organizeImports": "never" // 保存时不会自动整理 import
  },
  "editor.formatOnSave": false, // 保存文件时，不自动格式化代码
  // 指定 ESLint 要检查的文件类型
  "eslint.validate": [
    "html",
    "css",
    "scss",
    "json",
    "jsonc",
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact",
    "vue"
  ],
  // 显示语言（优先显示为简体中文）
  "i18n-ally.displayLanguage": "zh-cn",
  // 启用的解析器（这里表示用 TypeScript 解析翻译 key）
  "i18n-ally.enabledParsers": ["ts"],
  // 启用的框架（这里是 Vue 项目）
  "i18n-ally.enabledFrameworks": ["vue"],
  // 优先在编辑器中直接编辑翻译（而不是弹出窗口）
  "i18n-ally.editor.preferEditor": true,
  // key 风格：nested 表示使用嵌套结构（例如：home.title）
  "i18n-ally.keystyle": "nested",
  // 语言文件所在目录（翻译文件路径）
  "i18n-ally.localesPaths": ["src/locales/langs"],
  // TypeScript 解析器的编译配置
  "i18n-ally.parsers.typescript.compilerOptions": {
    // 使用与项目一致的模块解析规则
    "moduleResolution": "node"
  },
  // 关闭 Prettier 插件
  "prettier.enable": false,
  // 指定 UnoCSS 从项目根目录开始扫描文件
  "unocss.root": ["./"],
  // 让 vscode 使用项目本地安装的 TypeScript 版本，而不是内置版本
  "js/ts.tsdk.path": "node_modules/typescript/lib",
  "i18n-ally.sourceLanguage": "zh-cn"
}
